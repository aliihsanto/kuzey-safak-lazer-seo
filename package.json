{
  "name": "safak-lazer",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:ssr": "ng build && ng run safak-lazer:server",
    "serve:ssr": "node dist/safak-lazer/server/main.js",
    "generate:sitemap": "node generate-sitemap.js",
    "prerender": "npm run generate:sitemap && ng run safak-lazer:prerender",
    "watch": "ng build --watch --configuration development",
    "dev:ssr": "ng run safak-lazer:serve-ssr",
    "test": "ng test"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "~13.2.0",
    "@angular/common": "~13.2.0",
    "@angular/compiler": "~13.2.0",
    "@angular/core": "~13.2.0",
    "@angular/forms": "~13.2.0",
    "@angular/platform-browser": "~13.2.0",
    "@angular/platform-browser-dynamic": "~13.2.0",
    "@angular/platform-server": "^13.2.7",
    "@angular/router": "~13.2.0",
    "@nguniversal/builders": "^13.1.1",
    "@nguniversal/express-engine": "^13.1.1",
    "@ngx-translate/core": "^13.0.0",
    "@ngx-translate/http-loader": "^6.0.0",
    "@types/express": "^5.0.6",
    "express": "^5.2.1",
    "rxjs": "~7.5.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.11.4"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "~13.2.6",
    "@angular/cli": "~13.2.6",
    "@angular/compiler-cli": "~13.2.0",
    "@types/jasmine": "~3.10.0",
    "@types/node": "^12.11.1",
    "jasmine-core": "~4.0.0",
    "karma": "~6.3.0",
    "karma-chrome-launcher": "~3.1.0",
    "karma-coverage": "~2.1.0",
    "karma-jasmine": "~4.0.0",
    "karma-jasmine-html-reporter": "~1.7.0",
    "sharp": "^0.34.5",
    "typescript": "~4.5.2",
    "video.js": "^8.17.4"
  }
}
